{
  "name": "amble-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "expo start --android",
    "android:preview": "npx eas-cli build -p android --profile preview",
    "android:prod": "npx eas-cli build -p android --profile production",
    "android:submit": "npx eas-cli submit -p android --latest",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export -p web",
    "preview:web": "npx serve dist",
    "reset-project": "node ./scripts/reset-project.js"
  },
  "dependencies": {
    "@expo-google-fonts/montserrat": "^0.4.2",

    "@react-native-community/datetimepicker": "8.0.1",
    "axios": "^1.13.6",
    "expo": "~51.0.39",
    "expo-blur": "~13.0.2",
    "expo-constants": "~16.0.2",
    "expo-font": "~12.0.5",
    "expo-haptics": "~13.0.1",
    "expo-image-picker": "~15.1.0",
    "expo-linear-gradient": "~13.0.2",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.14",
    "expo-splash-screen": "~0.27.4",
    "expo-status-bar": "~1.12.1",
    "expo-symbols": "~0.1.0",
    "react": "18.2.0",
